// Schema Prisma Completo para o Portal de Gestão de Pessoas
// Copie este conteúdo para: backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELO DE USUÁRIO (Estagiário 1)
// ==========================================
model User {
  id           String   @id @default(uuid())
  ra           String   @unique  // NOVO - Registro Acadêmico (7 dígitos)
  nome         String
  email        String   @unique
  senha        String
  tipo         UserType
  foto         String?
  cargo        String?
  departamento String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  avaliacoesFeitas    Evaluation[] @relation("AvaliadorRelation")
  avaliacoesRecebidas Evaluation[] @relation("AvaliadoRelation")
  nineBoxAvaliacoes   NineBox[]

  @@index([ra])  // Índice para busca rápida por RA
  @@map("users")
}

enum UserType {
  admin        // NOVO - Administrador (criado apenas via seed)
  gestor       // Gerente/Gestor
  colaborador  // Colaborador/Funcionário
}

// ==========================================
// MODELO DE AVALIAÇÃO (Estagiário 2)
// ==========================================
model Evaluation {
  id          String   @id @default(uuid())
  tipo        String   // 'gestor' ou 'colaborador'
  avaliadorId String
  avaliadoId  String
  criterios   Json     // { pontualidade: 5, comunicacao: 4, ... }
  media       Float?
  comentario  String?
  data        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  avaliador User @relation("AvaliadorRelation", fields: [avaliadorId], references: [id], onDelete: Cascade)
  avaliado  User @relation("AvaliadoRelation", fields: [avaliadoId], references: [id], onDelete: Cascade)

  @@index([avaliadoId])
  @@index([avaliadorId])
  @@index([data])
  @@map("evaluations")
}

// ==========================================
// MODELO NINE BOX (Estagiário 2)
// ==========================================
model NineBox {
  id          String   @id @default(uuid())
  pessoaId    String
  performance Int      // 1 (Baixo), 2 (Médio), 3 (Alto)
  potential   Int      // 1 (Baixo), 2 (Médio), 3 (Alto)
  categoria   String   // Superstar, Estrela, Especialista, etc.
  comentario  String?
  data        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  pessoa User @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId])
  @@index([data])
  @@map("nine_box")
}

// ==========================================
// MODELO DE COMPETÊNCIA (Estagiário 3)
// ==========================================
model Competency {
  id            String   @id @default(uuid())
  nome          String
  descricao     String
  tipo          String   // 'desempenho', 'comportamento', 'tecnica', 'lideranca'
  competenciaDe String   // 'gestor', 'colaborador', 'todos'
  criterios     Json     // Array de strings com os critérios
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tipo])
  @@index([competenciaDe])
  @@map("competencies")
}

